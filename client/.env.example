# Outbound bridge domain. The well-known _smtp record must be served here with
# a CORS-open Access-Control-Allow-Origin header:
#   https://<domain>/.well-known/nostr.json?name=_smtp
# Use stg.mailstr.app to point a local build at staging.
VITE_BRIDGE_DOMAIN=mailstr.app

# Where the browser sends API requests.
#
# Leave UNSET for local development. api.formstr.app allows only a fixed set of
# origins and answers any other with a 500 rather than a CORS rejection, so the
# browser cannot call it directly from localhost — an unset value makes requests
# same-origin and Vite's /api proxy forwards them upstream.
#
# Set it to http://localhost:5000 to develop against a local backend, or to
# https://api.formstr.app for a production build.
# VITE_API_BASE_URL=https://api.formstr.app

# The URL the backend believes it serves. NIP-98 signs this into the `u` tag,
# which must match the URL the server receives — not the proxied one the
# browser requested. Only change this if the API moves.
# VITE_API_CANONICAL_BASE_URL=https://api.formstr.app

# Upstream for the dev proxy. Point at a local backend if you run one.
# VITE_API_PROXY_TARGET=https://api.formstr.app
