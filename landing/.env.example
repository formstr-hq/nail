# Host directory the built site is copied into (served by the external nginx)
LANDING_DIST_PATH=/var/www/mailstr

# formstr-backend origin the signup flow talks to
VITE_API_BASE_URL=https://api.formstr.app
VITE_WS_BASE_URL=wss://api.formstr.app

# Address domain and mail-UI location
VITE_MAIL_DOMAIN=mailstr.app
VITE_MAILS_URL=/mails
